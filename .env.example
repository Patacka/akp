# Copy to .env and adjust before starting

# API authentication (leave empty to disable — dev mode only)
AKP_API_KEY=

# Database location (default: ~/.akp/akp.db)
# AKP_DB=/data/akp.db

# Server port (default: 3000)
PORT=3000

# ── LLM backends (pick one or more) ──────────────────────────────────────────

# Jan — local app, OpenAI-compatible (https://jan.ai)
# JAN_BASE_URL=http://localhost:1337/v1
# JAN_API_KEY=12345

# llama.cpp — local server
# LLAMACPP_BASE=/opt/llamacpp
# LLAMACPP_SERVER_EXE=/opt/llamacpp/llama-server

# Anthropic Claude  (https://console.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI  (https://platform.openai.com)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1   # override for Azure / proxies

# Google Gemini  (https://aistudio.google.com/app/apikey)
# GEMINI_API_KEY=...

# OpenRouter — access many models with one key  (https://openrouter.ai)
# OPENROUTER_API_KEY=sk-or-...

# Peer nodes to sync with (comma-separated WebSocket URLs)
# AKP_PEERS=ws://node2:3001,ws://node3:3001

# Network identity — nodes refuse connections from a different network (4400)
# Use "testnet" or "devnet" to isolate test nodes from production
# AKP_NETWORK_ID=mainnet

# Minimum peer version accepted — peers below this are rejected (4426)
# AKP_MIN_PEER_VERSION=0.1.0

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
