{
  "name": "agent-knowledge-protocol",
  "version": "0.1.1",
  "description": "Agent Knowledge Protocol — decentralised, peer-reviewed knowledge graph for AI agents",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "akp": "dist/cli/akp.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "start": "node dist/cli/akp.js start",
    "relay": "tsx src/relay.ts",
    "build": "tsc",
    "build:ui": "cd ui && npm run build",
    "prepublishOnly": "npm run build",
    "dev": "tsx watch src/cli/akp.ts start --mock-stage1",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "tsx src/bench/report.ts",
    "experiment": "tsx src/experiments/run.ts",
    "experiment:e1": "tsx src/experiments/run.ts --experiment E1",
    "experiment:e2": "tsx src/experiments/run.ts --experiment E2",
    "experiment:e3": "tsx src/experiments/run.ts --experiment E3",
    "experiment:e4": "tsx src/experiments/run.ts --experiment E4",
    "experiment:e5": "tsx src/experiments/run.ts --experiment E5",
    "experiment:jan": "tsx src/experiments/run.ts --provider jan --model auto",
    "experiment:claude": "tsx src/experiments/run.ts --provider claude",
    "experiment:openai": "tsx src/experiments/run.ts --provider openai",
    "experiment:gemini": "tsx src/experiments/run.ts --provider gemini",
    "experiment:openrouter": "tsx src/experiments/run.ts --provider openrouter",
    "experiment:sweep": "tsx src/experiments/multi-model-sweep.ts",
    "experiment:report": "tsx src/experiments/multi-model-report.ts",
    "experiment:calibrate": "tsx src/pipeline/calibration.ts",
    "bench:cap": "tsx src/bench/cap-analysis.ts",
    "bench:gossip": "tsx src/bench/gossip-scale.ts",
    "registry": "tsx src/sync/registry.ts"
  },
  "keywords": [
    "agent",
    "knowledge",
    "protocol",
    "dht",
    "kademlia",
    "crdt",
    "did",
    "mcp",
    "ai",
    "decentralised",
    "peer-to-peer"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Patacka/akp.git"
  },
  "homepage": "https://github.com/Patacka/akp#readme",
  "bugs": {
    "url": "https://github.com/Patacka/akp/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@automerge/automerge": "^3.0.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@noble/ed25519": "^2.0.0",
    "@noble/hashes": "^1.4.0",
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "jayson": "^4.1.0",
    "pino": "^10.3.1",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
